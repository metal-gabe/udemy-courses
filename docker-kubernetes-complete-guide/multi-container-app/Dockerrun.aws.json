{
   "AWSEBDockerrunVersion": 2,
   "containerDefinitions": [
      {
         "essential": false,
         "hostname": "client",
         "image": "your-docker-id/multi-client",
         "memory": 512,
         "name": "client"
      },
      {
         "essential": false,
         "hostname": "api",
         "image": "your-docker-id/multi-server",
         "memory": 512,
         "name": "server"
      },
      {
         "essential": false,
         "hostname": "worker",
         "image": "your-docker-id/multi-worker",
         "memory": 512,
         "name": "worker"
      },
      {
         "essential": true,
         "hostname": "nginx",
         "image": "your-docker-id/multi-nginx",
         "links": ["client", "server"],
         "memory": 512,
         "name": "nginx",
         "portMappings": [
            {
               "containerPort": 80,
               "hostPort": 80
            }
         ]
      }
   ]
}
